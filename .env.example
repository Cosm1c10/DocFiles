# Supabase Configuration
# Get these from https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Google Gemini API
# Get your API key from https://makersuite.google.com/app/apikey
# ⚠️ CRITICAL: Only use in Edge Functions (server-side), NEVER in frontend
GEMINI_API_KEY=your-gemini-api-key-here

# USDA FoodData Central API (for nutrition data)
# Get your API key from https://fdc.nal.usda.gov/api-key-signup.html
# Optional: defaults to DEMO_KEY (rate-limited)
USDA_API_KEY=your-usda-api-key-here

# Environment
NODE_ENV=development

# Optional: For local development with Supabase CLI
# NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key
